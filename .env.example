# Application title displayed in the browser tab and header
VITE_APP_TITLE=Wealth Portal

# Base URL for API requests (optional, defaults to /api)
# VITE_API_BASE_URL=http://localhost:3000/api

# Enable or disable dark mode by default (optional, defaults to false)
# VITE_DEFAULT_DARK_MODE=false

# Currency code used for formatting monetary values (optional, defaults to USD)
# VITE_DEFAULT_CURRENCY=USD

# Locale used for number and date formatting (optional, defaults to en-US)
# VITE_DEFAULT_LOCALE=en-US